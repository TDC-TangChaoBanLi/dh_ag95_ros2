<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Pure visual/collision/kinematic description macro, no ros2_control tags. -->
  <xacro:macro name="dh_ag95_gripper" params="prefix:=dh_ag95 parent:=world *origin">
    <link name="${prefix}_base_link">
      <visual>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <geometry><box size="0.085 0.045 0.05"/></geometry>
        <material name="${prefix}_dark_gray"><color rgba="0.15 0.15 0.15 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <geometry><box size="0.085 0.045 0.05"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="${prefix}_mount_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}_base_link"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <link name="${prefix}_left_finger_link">
      <visual>
        <origin xyz="0 0.0275 0.085" rpy="0 0 0"/>
        <geometry><box size="0.018 0.018 0.07"/></geometry>
        <material name="${prefix}_silver"><color rgba="0.75 0.75 0.75 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0.0275 0.085" rpy="0 0 0"/>
        <geometry><box size="0.018 0.018 0.07"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0.0275 0.085" rpy="0 0 0"/>
        <mass value="0.15"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <link name="${prefix}_right_finger_link">
      <visual>
        <origin xyz="0 -0.0275 0.085" rpy="0 0 0"/>
        <geometry><box size="0.018 0.018 0.07"/></geometry>
        <material name="${prefix}_silver"/>
      </visual>
      <collision>
        <origin xyz="0 -0.0275 0.085" rpy="0 0 0"/>
        <geometry><box size="0.018 0.018 0.07"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 -0.0275 0.085" rpy="0 0 0"/>
        <mass value="0.15"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <!-- Normalized opening joint: 0.0=open, 1.0=closed by default in the driver mapping. -->
    <joint name="${prefix}_finger_joint" type="prismatic">
      <parent link="${prefix}_base_link"/>
      <child link="${prefix}_left_finger_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 -1 0"/>
      <limit lower="0.0" upper="1.0" effort="100" velocity="1.0"/>
    </joint>

    <joint name="${prefix}_right_finger_mimic_joint" type="prismatic">
      <parent link="${prefix}_base_link"/>
      <child link="${prefix}_right_finger_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.0" effort="100" velocity="1.0"/>
      <mimic joint="${prefix}_finger_joint" multiplier="1.0" offset="0.0"/>
    </joint>
  </xacro:macro>
</robot>
