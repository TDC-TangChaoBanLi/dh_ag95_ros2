<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!--
    DH-Robotics AG-95 description macro.

    This file reorganizes the public DH-Robotics AG-95 ROS1 description into a ROS2-friendly xacro macro.
    Main kinematic values, joint names, mimic multipliers, inertial values and mesh filenames are taken
    from the official dh_robotics_ag95_description xacro.
  -->

  <xacro:macro name="dh_ag95_gripper" params="
    prefix 
    parent 
    *origin">

    <material name="${prefix}dh_ag95_gripper_black_material" >
      <color rgba="0.15 0.15 0.15 1.0"/>
    </material>
    <material name="${prefix}dh_ag95_gripper_white_material" >
      <color rgba="0.85 0.85 0.85 1.0"/>
    </material>

    <joint name="${prefix}gripper_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}gripper_base_link"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <link name="${prefix}gripper_base_link">
      <visual>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/base_link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}dh_ag95_gripper_black_material"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/base_link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.83416"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.0013016" ixy="-6.9374e-07" ixz="5.9848e-07" iyy="0.00049972" iyz="2.0244e-07" izz="0.001498"/>
      </inertial>
    </link>

    <joint name="${prefix}gripper_finger1_joint" type="revolute">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}gripper_finger1_knuckle_link"/>
      <axis xyz="0 -1 0"/>
      <origin rpy="0 0 ${pi}" xyz="-0.016 0 0.10586"/>
      <limit lower="0.0" upper="0.65" velocity="2.0" effort="1000"/>
    </joint>

    <joint name="${prefix}gripper_finger2_joint" type="revolute">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}gripper_finger2_knuckle_link"/>
      <axis xyz="0 -1 0"/>
      <origin rpy="0 0 0" xyz="0.016 0 0.10586"/>
      <limit lower="-3.14" upper="3.14" velocity="100.0" effort="1000"/>
      <mimic joint="${prefix}gripper_finger1_joint" multiplier="1.0" offset="0.0"/>
    </joint>

    <link name="${prefix}gripper_finger1_knuckle_link">
      <visual>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/crank_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}dh_ag95_gripper_white_material"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/crank_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.011111"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="3.88172e-06" ixy="-2.29456e-13" ixz="8.33e-07" iyy="1.92174e-06" iyz="2.04435e-13" izz="4.32374e-06"/>
      </inertial>
    </link>

    <link name="${prefix}gripper_finger2_knuckle_link">
      <visual>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/crank_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}dh_ag95_gripper_white_material"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/crank_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.011111"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="3.88172e-06" ixy="-2.29456e-13" ixz="8.33e-07" iyy="1.92174e-06" iyz="2.04435e-13" izz="4.32374e-06"/>
      </inertial>
    </link>

    <joint name="${prefix}gripper_finger1_finger_joint" type="continuous">
      <parent link="${prefix}gripper_finger1_knuckle_link"/>
      <child link="${prefix}gripper_finger1_finger_link"/>
      <axis xyz="0 -1 0"/>
      <origin xyz="0.0292080077784 0 -0.0227132622407" rpy="0 0 0"/>
      <limit lower="-3.14" upper="3.14" velocity="100.0" effort="0.1"/>
      <mimic joint="${prefix}gripper_finger1_joint" multiplier="0.4563942" offset="0"/>
    </joint>

    <joint name="${prefix}gripper_finger2_finger_joint" type="continuous">
      <parent link="${prefix}gripper_finger2_knuckle_link"/>
      <child link="${prefix}gripper_finger2_finger_link"/>
      <axis xyz="0 -1 0"/>
      <origin xyz="0.0292080077784 0 -0.0227132622407" rpy="0 0 0"/>
      <limit lower="-3.14" upper="3.14" velocity="100.0" effort="0.1"/>
      <mimic joint="${prefix}gripper_finger1_joint" multiplier="0.4563942" offset="0"/>
    </joint>

    <link name="${prefix}gripper_finger1_finger_link">
      <visual>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/rod_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}dh_ag95_gripper_black_material"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/rod_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.0222871"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="8.72836e-06" ixy="7.0843e-15" ixz="-2.18833e-06" iyy="7.26157e-06" iyz="7.6579e-15" izz="3.3425e-06"/>
      </inertial>
    </link>

    <link name="${prefix}gripper_finger2_finger_link">
      <visual>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/rod_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}dh_ag95_gripper_black_material"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/rod_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.0222871"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="8.72836e-06" ixy="7.0843e-15" ixz="-2.18833e-06" iyy="7.26157e-06" iyz="7.6579e-15" izz="3.3425e-06"/>
      </inertial>
    </link>

    <joint name="${prefix}gripper_finger1_inner_knuckle_joint" type="continuous">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}gripper_finger1_inner_knuckle_link"/>
      <axis xyz="0 -1 0"/>
      <origin rpy="0 0 ${pi}" xyz="-0.016 0 0.10586"/>
      <limit lower="-3.14" upper="3.14" velocity="100.0" effort="0.1"/>
      <mimic joint="${prefix}gripper_finger1_joint" multiplier="1.49462955" offset="0"/>
    </joint>

    <joint name="${prefix}gripper_finger2_inner_knuckle_joint" type="continuous">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}gripper_finger2_inner_knuckle_link"/>
      <axis xyz="0 -1 0"/>
      <origin rpy="0 0 0" xyz="0.016 0 0.10586"/>
      <limit lower="-3.14" upper="3.14" velocity="100.0" effort="0.1"/>
      <mimic joint="${prefix}gripper_finger1_joint" multiplier="1.49462955" offset="0"/>
    </joint>

    <link name="${prefix}gripper_finger1_inner_knuckle_link">
      <visual>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/proximal_phalanx_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}dh_ag95_gripper_black_material"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/proximal_phalanx_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.0318004"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="1.39848e-05" ixy="-9.54763e-15" ixz="-5.01422e-06" iyy="1.04943e-05" iyz="8.94585e-16" izz="1.36183e-05"/>
      </inertial>
    </link>

    <link name="${prefix}gripper_finger2_inner_knuckle_link">
      <visual>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/proximal_phalanx_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}dh_ag95_gripper_black_material"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/proximal_phalanx_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.0318004"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="1.39848e-05" ixy="-9.54763e-15" ixz="-5.01422e-06" iyy="1.04943e-05" iyz="8.94585e-16" izz="1.36183e-05"/>
      </inertial>
    </link>

    <joint name="${prefix}gripper_finger1_finger_tip_joint" type="continuous">
      <parent link="${prefix}gripper_finger1_inner_knuckle_link"/>
      <child link="${prefix}gripper_finger1_finger_tip_link"/>
      <axis xyz="0 1 0"/>
      <origin xyz="0.0394969463769 0 0.0382752038125" rpy="0 0 0"/>
      <limit lower="-3.14" upper="3.14" velocity="100.0" effort="0.1"/>
      <mimic joint="${prefix}gripper_finger1_joint" multiplier="1.49462955" offset="0"/>
    </joint>

    <joint name="${prefix}gripper_finger2_finger_tip_joint" type="continuous">
      <parent link="${prefix}gripper_finger2_inner_knuckle_link"/>
      <child link="${prefix}gripper_finger2_finger_tip_link"/>
      <axis xyz="0 1 0"/>
      <origin xyz="0.0394969463769 0 0.0382752038125" rpy="0 0 0"/>
      <limit lower="-3.14" upper="3.14" velocity="100.0" effort="0.1"/>
      <mimic joint="${prefix}gripper_finger1_joint" multiplier="1.49462955" offset="0"/>
    </joint>

    <link name="${prefix}gripper_finger1_finger_tip_link">
      <visual>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/distal_phalanx_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}dh_ag95_gripper_white_material"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/distal_phalanx_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.0124305"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="2.84217e-06" ixy="-2.48048e-15" ixz="8.24539e-07" iyy="3.03961e-06" iyz="2.16427e-13" izz="1.11815e-06"/>
      </inertial>
    </link>

    <link name="${prefix}gripper_finger2_finger_tip_link">
      <visual>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/distal_phalanx_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}dh_ag95_gripper_white_material"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://dh_ag95_description/meshes/visual/distal_phalanx_Link.STL" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.0124305"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="2.84217e-06" ixy="-2.48048e-15" ixz="8.24539e-07" iyy="3.03961e-06" iyz="2.16427e-13" izz="1.11815e-06"/>
      </inertial>
    </link>
  </xacro:macro>
</robot>
